rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role;
    }

    function isStaff() {
      return getUserRole() in ['Super Admin', 'Admin', 'Document Officer', 'Application User'];
    }

    match /students/{studentId} {
      allow read: if isAuthenticated() && (isStaff() || resource.data.partnerId == request.auth.uid);
      allow write: if isAuthenticated() && (isStaff());
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && getUserRole() in ['Super Admin', 'Admin'];
      // Lets a signed-in user update ONLY their own online/lastSeen presence
      // fields (used for the chat "who's online" indicator), without needing
      // Super Admin / Admin rights, and without opening up any other field.
      allow update: if isAuthenticated() &&
        request.auth.token.email == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['online', 'lastSeen']);
    }

    match /chatMessages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.group == 'global' ||
        (resource.data.group == 'staff-only' && isStaff()) ||
        (resource.data.isDirect == true &&
          (resource.data.senderEmail == request.auth.token.email ||
           resource.data.toEmail == request.auth.token.email))
      );
      allow create: if isAuthenticated() &&
        request.resource.data.senderEmail == request.auth.token.email && (
          request.resource.data.group == 'global' ||
          (request.resource.data.group == 'staff-only' && isStaff()) ||
          (request.resource.data.isDirect == true && request.resource.data.toEmail is string)
        );
      allow update, delete: if false;
    }
  }
}
